menu "TrackCluster — Right cluster pin map (Waveshare ESP32-S3-Touch-LCD-2.8C)"

    # ── Pin assignments verified against ESP32-S3-Touch-LCD-2.8C schematic ──
    #
    # Board-reserved GPIOs (do NOT reassign):
    #   GPIO 1        → LCD_SDA (panel SPI init, shared with SD MOSI)
    #   GPIO 2        → LCD_SCK (panel SPI init, shared with SD SCK)
    #   GPIO 3        → R2
    #   GPIO 5        → B1
    #   GPIO 6        → BL_PWM  ← EXTERNAL PWM CONTROLLER — firmware does NOT touch
    #   GPIO 7        → I²C SCL (TCA9554, GT911, IMU, RTC — shared bus)
    #   GPIO 8        → R3
    #   GPIO 9–14     → G5–G0
    #   GPIO 15       → I²C SDA
    #   GPIO 16       → TP_INT (GT911 interrupt)
    #   GPIO 17–18    → R5, R4
    #   GPIO 21       → B5
    #   GPIO 38–41    → HSYNC, VSYNC, DE, PCLK
    #   GPIO 45–48    → B2–B4, R1
    #   GPIO 43       → UART0 TX (J9) — inter-cluster TX reserved
    #   GPIO 44       → UART0 RX (J9) — inter-cluster RX from center
    #
    # TCA9554 I/O expander (addr 0x20 on I²C bus):
    #   P0 = LCD_RST  P1 = TP_RST  P2 = LCD_CS  P4 = SD_CS
    #
    # Backlight: GPIO6 (BL_PWM) is driven by an external PWM controller wired
    # to the display FPC connector. The firmware never touches GPIO6.

    config TC_UART_RX_GPIO
        int "UART RX GPIO ← center cluster TX (J9 connector)"
        range 0 48
        default 44
        help
            GPIO44 is the UART0 RX broken out on J9. The center board's
            UART1 TX (GPIO17) connects here. Firmware maps UART1 to this pin.

    config TC_UART_TX_GPIO
        int "UART TX GPIO → center cluster RX (J9 connector, reserved)"
        range 0 48
        default 43

    config TC_I2C_SCL_GPIO
        int "I²C SCL (TCA9554 expander + GT911 touch)"
        range 0 48
        default 7

    config TC_I2C_SDA_GPIO
        int "I²C SDA"
        range 0 48
        default 15

    config TC_TP_INT_GPIO
        int "GT911 touch interrupt"
        range 0 48
        default 16

endmenu
